# Server
PORT=3000
# CORS allowlist (comma-separated, no trailing slash)
FRONTEND_URL=http://localhost:5173

# AI
GEMINI_API_KEY=your-gemini-api-key
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Supabase (REST/API usage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Database (TypeORM) - use EITHER DATABASE_URL or split DB_* vars
# Option A: Single connection string (recommended for Supabase)
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres
DB_SSL=true

# Option B: Split fields
# DB_TYPE=postgres
# DB_HOST=db.your-project-ref.supabase.co
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=your-db-password
# DB=postgres
